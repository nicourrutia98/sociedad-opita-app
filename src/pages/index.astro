---
import '../styles/global.css';

export const prerender = true;
---

<html lang="es-CO">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Sociedad Opita — el primer monumento digital vivo de una comunidad colombiana. Tello, Huila." />
    <title>Sociedad Opita — Próximamente</title>
  </head>
  <body class="bg-opita-arena text-opita-cafe">
    <main class="max-w-2xl mx-auto px-6 py-24">
      <h1 class="text-5xl font-serif text-opita-tierra mb-4">Sociedad Opita</h1>
      <p class="text-xl mb-6">
        El primer monumento digital vivo de una comunidad colombiana.
      </p>
      <p class="text-lg mb-6 leading-relaxed">
        Tello, Huila. Sus 41 personas. Sus chismes. Su tinto de las 6 AM.
        Te estamos dejando asomarte. Muy pronto.
      </p>
      <p class="text-base mb-8 leading-relaxed text-opita-tierra">
        Mientras construimos, puedes leer el
        <a href="https://github.com/nicourrutia98/sociedad-opita" class="underline hover:text-opita-verriondo">
          paper académico
        </a>
        o visitar el
        <a href="/forense" class="underline hover:text-opita-verriondo">
          mapa forense de la versión anterior
        </a>.
      </p>
      <p class="text-sm italic text-opita-tierra">
        Hecho por un nativo huilense, en el Huila, con IA, para que Tello no se muera
        cuando los pelaos se vayan pa' Bogotá.
      </p>
    </main>
  </body>
</html>
